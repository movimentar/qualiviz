# =========================================================
# QualiViz - Git Ignore
# =========================================================

# ---------------------------------------------------------
# R Session Files
# ---------------------------------------------------------
.Rhistory
.Rapp.history
.RData
.RDataTmp
.Ruserdata

# ---------------------------------------------------------
# Environment Variables / Secrets
# ---------------------------------------------------------
.Renviron
.Renviron.*
!.Renviron.example

# ---------------------------------------------------------
# RStudio
# ---------------------------------------------------------
.Rproj.user/
*.Rproj

# If you want to keep qualiviz.Rproj in the repository,
# comment the line above and uncomment below:
# !qualiviz.Rproj

# ---------------------------------------------------------
# Shiny Deployment
# ---------------------------------------------------------
rsconnect/

# ---------------------------------------------------------
# Generated Lexicons
# ---------------------------------------------------------
data/*.rds
!data/.gitkeep

# ---------------------------------------------------------
# Build Outputs
# ---------------------------------------------------------
*.tar.gz
*.Rcheck/

# ---------------------------------------------------------
# Package Build Examples
# ---------------------------------------------------------
*-Ex.R

# ---------------------------------------------------------
# OAuth / Authentication
# ---------------------------------------------------------
.httr-oauth
.httr-oauth-cache

# ---------------------------------------------------------
# R Markdown / Quarto
# ---------------------------------------------------------
*_cache/
cache/
_files/
*_files/

*.utf8.md
*.knit.md

# ---------------------------------------------------------
# Generated Documentation
# ---------------------------------------------------------
README.html
docs/

# ---------------------------------------------------------
# Vignettes
# ---------------------------------------------------------
vignettes/*.html
vignettes/*.pdf

# ---------------------------------------------------------
# Temporary Files
# ---------------------------------------------------------
*.tmp
*.temp
*.bak
*.swp
*~

# ---------------------------------------------------------
# Operating System Files
# ---------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
*.log

# ---------------------------------------------------------
# Python (future-proof)
# ---------------------------------------------------------
__pycache__/
*.pyc

# ---------------------------------------------------------
# IDEs
# ---------------------------------------------------------
.vscode/
.idea/

# ---------------------------------------------------------
# Testing / Coverage
# ---------------------------------------------------------
coverage/
covr/

# ---------------------------------------------------------
# Local Data Exports
# ---------------------------------------------------------
exports/
output/
results/

# ---------------------------------------------------------
# Screenshots generated during development
# ---------------------------------------------------------
screenshots/

# ---------------------------------------------------------
# Keep placeholders
# ---------------------------------------------------------
!data/.gitkeep